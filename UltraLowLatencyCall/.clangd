# .clangd — clangd configuration for the UltraLowLatencyCall JUCE project
#
# WHY THIS FILE EXISTS
# ────────────────────
# Visual Studio finds JUCE headers through include paths set in the .vcxproj
# file generated by Projucer.  The clangd language server (which powers
# IntelliSense / red-squiggle checks in VS Code) does NOT read .vcxproj files,
# so it cannot find <JuceHeader.h> or the juce:: namespace on its own.
#
# This file tells clangd where to look, eliminating "Use of undeclared
# identifier 'juce'" and similar false-positive errors.
#
# NOTE: These errors are IntelliSense-only.  The actual Visual Studio build
#       (Builds/VisualStudio2026/UltraLowLatencyCall.sln) is not affected.

CompileFlags:
  Add:
    # ── Include paths (mirrored from AdditionalIncludeDirectories in .vcxproj) ─
    - -IC:/JUCE/modules
    - -IC:/JUCE/modules/juce_audio_processors_headless/format_types/VST3_SDK
    - -IC:/JUCE/modules/juce_audio_plugin_client/VST3
    - -IC:/Users/tachi/Documents/UltraLowLatencyCall/UltraLowLatencyCall/JuceLibraryCode

    # ── vcpkg — third-party libraries (Opus, etc.) ────────────────────────────
    # vcpkg integrate install adds these to MSBuild automatically, but clangd
    # needs them listed here explicitly.
    - -IC:/vcpkg/installed/x64-windows/include

    # ── Core JUCE flags ────────────────────────────────────────────────────────
    # Tell JUCE that the global module settings block has already been included.
    - -DJUCE_GLOBAL_MODULE_SETTINGS_INCLUDED=1

    # Tell JUCE which modules are compiled into this project.
    - -DJUCE_MODULE_AVAILABLE_juce_audio_basics=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_devices=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_formats=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_plugin_client=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_processors=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_processors_headless=1
    - -DJUCE_MODULE_AVAILABLE_juce_audio_utils=1
    - -DJUCE_MODULE_AVAILABLE_juce_core=1
    - -DJUCE_MODULE_AVAILABLE_juce_data_structures=1
    - -DJUCE_MODULE_AVAILABLE_juce_events=1
    - -DJUCE_MODULE_AVAILABLE_juce_graphics=1
    - -DJUCE_MODULE_AVAILABLE_juce_gui_basics=1
    - -DJUCE_MODULE_AVAILABLE_juce_gui_extra=1

    # ── Plugin / standalone flags ──────────────────────────────────────────────
    - -DJucePlugin_Build_VST=0
    - -DJucePlugin_Build_VST3=1
    - -DJucePlugin_Build_Standalone=1
    - -DJUCE_STANDALONE_APPLICATION=1      # expands JucePlugin_Build_Standalone
    - -DJUCE_SHARED_CODE=1

    # ── Platform flags ─────────────────────────────────────────────────────────
    - -DWIN32=1
    - -D_WINDOWS=1
    - -D_CRT_SECURE_NO_WARNINGS=1

    # ── C++ standard ───────────────────────────────────────────────────────────
    - -std=c++17

  # Remove MSVC-specific flags that clangd does not understand.
  Remove:
    - /W*
    - /w*
    - /MP
    - /RTC*
    - /Z*
    - /GL
    - /Gm-
    - /fp*
